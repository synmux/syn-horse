// Dev-only wrangler config consumed exclusively by nitropack's built-in
// cloudflare-dev preset (via `nitro.cloudflareDev.configPath` in
// `nuxt.config.ts`) so that `wrangler.getPlatformProxy()` can stand up a
// Miniflare emulation of our Cloudflare bindings during `bun run dev`.
//
// Why a non-standard filename: nitropack's cloudflare preset and wrangler CLI
// both auto-discover `wrangler.{json,jsonc,toml}` and would `defu`-merge the
// contents into the generated deploy config — every binding ends up declared
// twice in `.output/server/wrangler.json`. A non-`wrangler.{json,jsonc,toml}`
// name is invisible to those auto-discoverers, so the deploy path stays clean
// while dev still gets the bindings it needs.
//
// Why this is a strict subset of the deploy config: wrangler's
// `getPlatformProxy()` switches to a remote (authenticated) edge-preview session
// the moment any binding lacks local Miniflare emulation. AI, BROWSER, IMAGES
// and analytics-engine datasets all force that remote mode and will fail without
// Cloudflare API credentials — so they're commented out below. Uncomment them
// (and arrange auth) if/when dev code starts using them.
//
// Binding IDs duplicate the ones in `nuxt.config.ts` `nitro.cloudflare.wrangler`
// and `hub.{db,kv,cache,blob}` on purpose: keeping the same IDs means Miniflare
// reuses persistent local state in `.wrangler/state/v3/...` across runs.
{
  "compatibility_date": "2026-04-15",
  "compatibility_flags": ["nodejs_compat", "nodejs_compat_populate_process_env"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "syn-horse",
      "database_id": "2722c422-9352-45b5-9e7f-a4f6504e4f85"
    }
  ],
  "kv_namespaces": [
    { "binding": "KV", "id": "e8ba4689173e4710aaff726ce8ddb225" },
    { "binding": "CACHE", "id": "6d108e06dbe144ff9752c63084e4bd85" }
  ],
  "r2_buckets": [{ "binding": "BLOB", "bucket_name": "blob-syn-horse" }],
  "vars": {
    "NUXT_PUBLIC_TURNSTILE_SITE_KEY": "0x4AAAAAAC2QY6ZikvZ4TAQq"
  },
  "version_metadata": { "binding": "CF_VERSION_METADATA" }

  // Remote-only bindings — uncomment these (and authenticate locally) when dev
  // code starts using them. Leaving them in as a reference for the deploy-side
  // shape the production wrangler config (in `nuxt.config.ts`) declares.
  //
  // "ai": { "binding": "AI" },
  // "browser": { "binding": "BROWSER" },
  // "images": { "binding": "IMAGES" },
  // "analytics_engine_datasets": [
  //   { "binding": "ANALYTICS", "dataset": "syn-horse" }
  // ]
}
