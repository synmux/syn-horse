{
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@nuxt/content": "^3.14.0",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/icon": "^2.2.3",
    "@nuxt/image": "^2.0.0",
    "@nuxt/scripts": "^1.2.1",
    "@nuxthub/core": "^0.10.7",
    "@nuxtjs/seo": "^5.1.3",
    "@nuxtjs/turnstile": "^1.1.3",
    "@tailwindcss/vite": "^4.3.0",
    "@takumi-rs/core": "^1.7.0",
    "@takumi-rs/wasm": "^1.7.0",
    "better-sqlite3": "^12.10.0",
    "daisyui": "^5.5.23",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "nuxt": "^4.4.7",
    "nuxt-gtag": "^4.1.0",
    "nuxt-security": "^2.6.0",
    "tailwindcss": "^4.3.0",
    "uuid": "^14.0.0",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@anthropic-ai/claude-code": "^2.1.168",
    "@biomejs/biome": "2.4.16",
    "@catppuccin/daisyui": "^2.1.1",
    "@catppuccin/tailwindcss": "^1.0.0",
    "@tailwindcss/cli": "^4.3.0",
    "@types/node": "^25.9.2",
    "ctx7": "^0.5.1",
    "lefthook": "^2.1.9",
    "nitropack": "^2.13.4",
    "npm-run-all2": "^9.0.1",
    "nuxi": "^3.35.2",
    "skilld": "^2.0.0",
    "tsx": "^4.22.4",
    "ultracite": "7.8.2",
    "untun": "^0.1.3",
    "wrangler": "^4.98.0"
  },
  "name": "syn-horse",
  "scripts": {
    "build": "bun run-s build:nuxt types",
    "build:nuxt": "bun run nuxt build",
    "deploy": "bun run-s deploy:stamp deploy:hash build deploy:wrangler",
    "deploy:hash": "git rev-parse --short HEAD > .commithash",
    "deploy:nonprod": "bun run-s deploy:stamp deploy:hash build deploy:nonprod:wrangler",
    "deploy:nonprod:wrangler": "bun run wrangler versions upload",
    "deploy:stamp": "date -u +%FT%TZ > .buildtime",
    "deploy:wrangler": "bun run wrangler deploy",
    "dev": "TMPDIR=/tmp bun run nuxt dev",
    "format": "bun run biome format --write .",
    "generate": "bun run nuxt generate",
    "lint": "bun run run-s lint:ultracite lint:types",
    "lint:fix": "bun run ultracite fix --write",
    "lint:fix:unsafe": "bun run ultracite fix --write --unsafe",
    "lint:types": "bun run tsc --noEmit",
    "lint:ultracite": "bun run ultracite check",
    "postinstall": "bun run run-s postinstall:prepare",
    "postinstall:prepare": "bun run nuxt prepare",
    "types": "bun run wrangler types --config .output/server/wrangler.json",
    "preview": "bun run-s build preview:wrangler",
    "preview:wrangler": "bun run wrangler dev",
    "db:generate": "bun run drizzle-kit generate",
    "db:migrate:local": "bun run wrangler d1 migrations apply syn-horse --local --config wrangler.dev.jsonc",
    "db:migrate:remote": "bun run wrangler d1 migrations apply syn-horse --remote --config wrangler.dev.jsonc",
    "db:studio": "bun run drizzle-kit studio",
    "x:test": "vitest",
    "x:test:coverage": "vitest --coverage",
    "x:test:e2e": "playwright test",
    "x:test:e2e:ui": "playwright test --ui",
    "x:test:nuxt": "vitest --project nuxt",
    "x:test:unit": "vitest --project unit",
    "x:test:watch": "vitest --watch",
    "prepare": "lefthook install && (skilld prepare || true)"
  },
  "type": "module",
  "author": {
    "email": "syn@syn.as",
    "name": "syn",
    "url": "https://github.com/synmux"
  },
  "packageManager": "bun@1.3.14",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/synmux/syn-horse.git"
  },
  "trustedDependencies": [
    "@anthropic-ai/claude-code",
    "@parcel/watcher",
    "better-sqlite3",
    "esbuild",
    "onnxruntime-node",
    "protobufjs",
    "sharp",
    "vue-demi",
    "workerd"
  ]
}
