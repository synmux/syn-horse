  "dependencies": {
    "@libsql/client": "^0.17.4",
    "@nuxt/content": "^3.15.0",
    "@nuxt/eslint": "^1.16.0",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/icon": "^2.3.1",
    "@nuxt/image": "^2.0.0",
    "@nuxt/scripts": "^1.3.1",
    "@nuxthub/core": "^0.10.8",
    "@nuxtjs/seo": "^5.3.2",
    "@nuxtjs/turnstile": "^1.1.3",
    "@tailwindcss/vite": "^4.3.3",
    "@takumi-rs/core": "1.8.7",
    "@takumi-rs/wasm": "1.8.7",
    "better-sqlite3": "^12.11.1",
    "daisyui": "^5.6.18",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "eslint": "^10.7.0",
    "nuxt": "^4.4.8",
    "nuxt-gtag": "^4.1.0",
    "nuxt-security": "^2.6.0",
    "tailwindcss": "^4.3.3",
    "uuid": "^14.0.1",
    "vue": "^3.5.40",
    "vue-router": "^5.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@anthropic-ai/claude-code": "^2.1.214",
    "@catppuccin/daisyui": "^2.1.1",
    "@catppuccin/tailwindcss": "^1.0.0",
    "@storybloq/storybloq": "^1.8.0",
    "@tailwindcss/cli": "^4.3.3",
    "@types/node": "^26.1.1",
    "ctx7": "^0.5.5",
    "lefthook": "^2.1.10",
    "nitropack": "^2.13.4",
    "npm-run-all2": "^9.0.2",
    "nuxi": "^3.37.0",
    "prettier": "^3.9.5",
    "skilld": "^2.0.0",
    "tsx": "^4.23.1",
    "untun": "^0.1.3",
    "vite-plugin-eslint2": "^5.3.0",
    "wrangler": "^4.112.0"
  },
  "name": "syn-horse",
  "packageManager": "bun@1.3.14",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/synmux/syn-horse.git"
  },
  "scripts": {
    "build": "bun run-s build:nuxt types",
    "build:nuxt": "bun run nuxt build",
    "db:generate": "bun run drizzle-kit generate",
    "db:migrate:local": "bun run wrangler d1 migrations apply syn-horse --local --config wrangler.dev.jsonc",
    "db:migrate:remote": "bun run wrangler d1 migrations apply syn-horse --remote --config wrangler.dev.jsonc",
    "db:studio": "bun run drizzle-kit studio",
    "deploy": "bun run-s deploy:stamp deploy:hash deploy:wrangler",
    "deploy:hash": "git rev-parse --short HEAD > .commithash",
    "deploy:nonprod": "bun run-s deploy:stamp deploy:hash build deploy:nonprod:wrangler",
    "deploy:nonprod:wrangler": "bun run wrangler versions upload",
    "deploy:stamp": "date -u +%FT%TZ > .buildtime",
    "deploy:wrangler": "bun run wrangler deploy",
    "dev": "bun run nuxt dev",
    "format": "bun run run-s format:prettier format:trunk",
    "format:prettier": "bun run prettier --write .",
    "format:trunk": "bun run trunk fmt -a",
    "generate": "bun run nuxt generate",
    "lint": "bun run run-s lint:eslint lint:trunk lint:types",
    "lint:eslint": "bun run eslint .",
    "lint:eslint:fix": "bun run eslint . --fix",
    "lint:fix": "bun run run-s lint:eslint:fix lint:trunk:fix",
    "lint:trunk": "bun run trunk check -a",
    "lint:trunk:fix": "bun run trunk check -a --fix",
    "lint:types": "bun run tsc --noEmit",
    "postinstall": "bun run prepare",
    "prepare": "bun run-s prepare:skilld prepare:nuxt",
    "prepare:skilld": "skilld prepare || true",
    "prepare:nuxt": "bun run nuxt prepare",
    "preview": "bun run-s build preview:wrangler",
    "preview:wrangler": "bun run wrangler dev",
    "types": "bun run-s prepare:nuxt types:wrangler",
    "types:wrangler": "bun run wrangler types --config .output/server/wrangler.json",
    "x:test": "vitest",
    "x:test:coverage": "vitest --coverage",
    "x:test:e2e": "playwright test",
    "x:test:e2e:ui": "playwright test --ui",
    "x:test:nuxt": "vitest --project nuxt",
    "x:test:unit": "vitest --project unit",
    "x:test:watch": "vitest --watch"
  },
  "type": "module",
  "trustedDependencies": [
    "@anthropic-ai/claude-code",
    "@google/genai",
    "@parcel/watcher",
    "better-sqlite3",
    "esbuild",
    "lefthook",
    "onnxruntime-node",
    "protobufjs",
    "sharp",
    "unrs-resolver",
    "vue-demi",
    "workerd"
  ]
}
