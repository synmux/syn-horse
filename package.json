  "name": "syn-horse",
  "packageManager": "bun@1.3.9",
  "private": true,
  "scripts": {
    "build": "bun run nuxt build",
    "deploy": "bun run-s build deploy:wrangler",
    "deploy:nonprod": "bun run-s build deploy:nonprod:wrangler",
    "deploy:nonprod:wrangler": "bun run wrangler versions upload",
    "deploy:wrangler": "bun run wrangler deploy",
    "dev": "bun run nuxt dev",
    "format": "bun run run-s format:prettier format:trunk",
    "format:prettier": "bun run prettier --write .",
    "format:trunk": "bun run trunk fmt -a",
    "generate": "bun run nuxt generate",
    "lint": "bun run run-s lint:eslint lint:trunk lint:types",
    "lint:eslint": "bun run eslint .",
    "lint:eslint:fix": "bun run eslint . --fix",
    "lint:fix": "bun run run-s lint:eslint:fix lint:trunk:fix",
    "lint:trunk": "bun run trunk check -a",
    "lint:trunk:fix": "bun run trunk check -a --fix",
    "lint:types": "bun run tsc --noEmit",
    "postinstall": "bun run-s postinstall:trunk:install postinstall:prepare types types:format",
    "postinstall:prepare": "bun run nuxt prepare",
    "postinstall:trunk:install": "bun run trunk install",
    "postinstall:trunk:upgrade": "bun run trunk upgrade",
    "preview": "bun run-s build preview:wrangler",
    "preview:wrangler": "bun run wrangler dev",
    "types": "bun run wrangler types",
    "types:format": "bun run prettier --write worker-configuration.d.ts",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:unit": "vitest --project unit",
    "test:nuxt": "vitest --project nuxt",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "esbuild",
    "sharp",
    "unrs-resolver",
    "vue-demi",
    "workerd"
  ],
  "type": "module"
}
