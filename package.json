{
  "dependencies": {
    "ntfy": "^1.15.3",
    "pushover-js": "^1.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@anthropic-ai/claude-code": "^2.1.191",
    "@biomejs/biome": "^2.5.1",
    "@cloudflare/vitest-pool-workers": "^0.16.20",
    "@types/node": "^25.9.4",
    "ctx7": "^0.4.5",
    "npm-run-all2": "^9.0.2",
    "skilld": "^2.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "ultracite": "^7.8.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.105.0"
  },
  "name": "syn-horse-notifications",
  "scripts": {
    "db:migrate": "bun run wrangler d1 migrations apply syn-horse-notifications --remote",
    "db:migrate:local": "bun run wrangler d1 migrations apply syn-horse-notifications --local",
    "deploy": "bun run wrangler deploy",
    "dev": "bun run wrangler dev",
    "doctor:ultracite": "bun run ultracite doctor",
    "fix": "bun run ultracite fix",
    "fix:unsafe": "bun run ultracite fix --unsafe",
    "format": "bun run biome format --write .",
    "lint": "bun run run-s lint:ultracite lint:types",
    "lint:types": "bun run tsc --noEmit",
    "lint:ultracite": "bun run ultracite check",
    "postinstall": "bun run types",
    "start": "bun run dev",
    "types": "bun run wrangler types",
    "prepare": "skilld prepare || true"
  },
  "type": "module",
  "version": "0.0.0-dev",
  "author": {
    "email": "syn@syn.as",
    "name": "syn",
    "url": "https://github.com/synmux"
  },
  "packageManager": "bun@1.3.14",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/synmux/syn-horse.git"
  },
  "trustedDependencies": [
    "@anthropic-ai/claude-code",
    "@google/genai",
    "esbuild",
    "onnxruntime-node",
    "protobufjs",
    "sharp",
    "workerd"
  ]
}
