  "name": "syn-horse",
  "packageManager": "bun@1.3.9",
  "private": true,
  "scripts": {
    "build": "bun run nuxt build",
    "clean": "rm -rf .nuxt .output .data/db node_modules/.cache",
    "db:drop": "bun run nuxt-db drop",
    "db:drop-all": "bun run nuxt-db drop-all",
    "db:generate": "bun run nuxt-db generate",
    "db:mark-as-migrated": "bun run nuxt-db mark-as-migrated",
    "db:migrate": "bun run nuxt-db migrate",
    "db:migrate:remote": "bun run nuxt-db migrate --remote",
    "db:sql": "bun run nuxt-db sql",
    "db:squash": "bun run nuxt-db squash",
    "deploy": "bun run-s build deploy:upload",
    "deploy:nonprod": "bun run-s build deploy:version",
    "deploy:upload": "bun run wrangler deploy",
    "deploy:version": "bun run wrangler versions upload",
    "dev": "bun run nuxt dev",
    "format": "bun run-s format:prettier format:trunk",
    "format:prettier": "bun run prettier --write .",
    "format:trunk": "bun run trunk fmt -a",
    "lint": "bun run-s lint:eslint lint:trunk lint:types",
    "lint:eslint": "bun run eslint .",
    "lint:eslint:fix": "bun run eslint . --fix",
    "lint:fix": "bun run-s lint:eslint:fix lint:trunk:fix",
    "lint:trunk": "bun run trunk check -a",
    "lint:trunk:fix": "bun run trunk check -a --fix",
    "lint:types": "bun run tsc --noEmit",
    "postinstall": "bun run-s postinstall:trunk:ensure postinstall:prepare types types:format",
    "postinstall:prepare": "bun run nuxt prepare",
    "postinstall:trunk:ensure": "bun scripts/ensure-trunk.ts",
    "preview": "bun run-s build preview:wrangler",
    "preview:wrangler": "bun run wrangler dev",
    "test": "bun run vitest",
    "test:coverage": "bun run vitest --coverage",
    "test:e2e": "bun run playwright-core test",
    "test:e2e:ui": "bun run playwright-core test --ui",
    "test:nuxt": "bun run vitest --project nuxt",
    "test:unit": "bun run vitest --project unit",
    "test:watch": "bun run vitest --watch",
    "types": "bun run wrangler types",
    "types:format": "bun run prettier --write worker-configuration.d.ts"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "esbuild",
    "sharp",
    "unrs-resolver",
    "vue-demi",
    "workerd"
  ],
  "type": "module"
}
