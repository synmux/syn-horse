    "@nuxt/icon": "2.2.1",
    "@nuxt/image": "2.0.0",
    "@nuxt/scripts": "1.0.4",
    "@nuxthub/core": "0.10.7",
    "@nuxtjs/seo": "5.1.3",
    "@nuxtjs/turnstile": "1.1.2",
    "@tailwindcss/vite": "^4.2.4",
    "@takumi-rs/core": "^1.1.2",
    "@takumi-rs/wasm": "^1.1.2",
    "better-sqlite3": "^12.9.0",
    "daisyui": "^5.5.19",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "eslint": "^10.3.0",
    "node-gyp": "^12.3.0",
    "nuxt": "^4.4.4",
    "nuxt-gtag": "4.1.0",
    "nuxt-security": "2.5.1",
    "openai": "^6.36.0",
    "tailwindcss": "^4.2.4",
    "uuid": "^14.0.0",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@anthropic-ai/claude-code": "^2.1.126",
    "@catppuccin/daisyui": "^2.1.1",
    "@catppuccin/tailwindcss": "^1.0.0",
    "@tailwindcss/cli": "^4.2.4",
    "@trunkio/launcher": "^1.3.4",
    "@types/node": "^25.6.0",
    "nitro-cloudflare-dev": "^0.2.2",
    "nitropack": "^2.13.4",
    "npm-run-all2": "^8.0.4",
    "nuxi": "^3.35.1",
    "prettier": "^3.8.3",
    "skilld": "^1.7.2",
    "tsx": "^4.21.0",
    "untun": "^0.1.3",
    "vite-plugin-eslint2": "^5.1.0",
    "wrangler": "^4.87.0"
  },
  "name": "syn-horse",
  "packageManager": "bun@1.3.13",
  "private": true,
  "scripts": {
    "build": "bun run-s build:nuxt types",
    "build:nuxt": "bun run nuxt build",
    "deploy": "bun run-s deploy:stamp build deploy:wrangler",
    "deploy:nonprod": "bun run-s deploy:stamp build deploy:nonprod:wrangler",
    "deploy:nonprod:wrangler": "bun run wrangler versions upload",
    "deploy:stamp": "date -u +%FT%TZ > .buildtime",
    "deploy:wrangler": "bun run wrangler deploy",
    "dev": "bun run nuxt dev",
    "format": "bun run run-s format:prettier format:trunk",
    "format:prettier": "bun run prettier --write .",
    "format:trunk": "bun run trunk fmt -a",
    "generate": "bun run nuxt generate",
    "lint": "bun run run-s lint:eslint lint:trunk lint:types",
    "lint:eslint": "bun run eslint .",
    "lint:eslint:fix": "bun run eslint . --fix",
    "lint:fix": "bun run run-s lint:eslint:fix lint:trunk:fix",
    "lint:trunk": "bun run trunk check -a",
    "lint:trunk:fix": "bun run trunk check -a --fix",
    "lint:types": "bun run tsc --noEmit",
    "postinstall": "bun run-s types format postinstall:prepare",
    "postinstall:prepare": "bun run nuxt prepare",
    "types": "bun run wrangler types --config .output/server/wrangler.json",
    "preview": "bun run-s build preview:wrangler",
    "preview:wrangler": "bun run wrangler dev",
    "x:db:generate": "bun run drizzle-kit generate",
    "x:db:migrate:local": "bun run wrangler d1 migrations apply dave-io --local",
    "x:db:migrate:remote": "bun run wrangler d1 migrations apply dave-io --remote",
    "x:db:studio": "bun run drizzle-kit studio",
    "x:test": "vitest",
    "x:test:coverage": "vitest --coverage",
    "x:test:e2e": "playwright test",
    "x:test:e2e:ui": "playwright test --ui",
    "x:test:nuxt": "vitest --project nuxt",
    "x:test:unit": "vitest --project unit",
    "x:test:watch": "vitest --watch",
    "prepare": "skilld prepare || true"
  },
  "trustedDependencies": [
    "@anthropic-ai/claude-code",
    "@parcel/watcher",
    "better-sqlite3",
    "esbuild",
    "onnxruntime-node",
    "protobufjs",
    "sharp",
    "unrs-resolver",
    "vue-demi",
    "workerd"
  ],
  "type": "module"
}
