{
  "author": {
    "email": "dave@dave.io",
    "name": "Dave Williams",
    "url": "https://github.com/daveio"
  },
  "dependencies": {
    "@nuxt/eslint": "1.15.1",
    "@nuxt/fonts": "0.14.0",
    "@nuxt/icon": "2.2.1",
    "@nuxt/image": "2.0.0",
    "@nuxthub/core": "0.10.6",
    "@tailwindcss/vite": "^4.2.0",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.575.0",
    "nuxt": "^4.3.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.0",
    "three": "^0.183.0",
    "vue": "^3.5.28",
    "vue-router": "^5.0.2"
  },
  "devDependencies": {
    "@anthropic-ai/claude-code": "^2.1.47",
    "@trunkio/launcher": "^1.3.4",
    "@types/node": "^25.2.3",
    "nitro-cloudflare-dev": "^0.2.2",
    "nitropack": "^2.13.1",
    "node-gyp": "^12.2.0",
    "npm-run-all2": "^8.0.4",
    "nuxi": "^3.33.1",
    "prettier": "^3.8.1",
    "shadcn-nuxt": "^2.4.3",
    "tw-animate-css": "^1.4.0",
    "untun": "^0.1.3",
    "wrangler": "^4.66.0"
  },
  "name": "syn-horse",
  "packageManager": "bun@1.3.9",
  "private": true,
  "scripts": {
    "build": "bun run nuxt build",
    "deploy": "bun run-s build deploy:wrangler",
    "deploy:nonprod": "bun run-s build deploy:nonprod:wrangler",
    "deploy:nonprod:wrangler": "bun run wrangler versions upload",
    "deploy:wrangler": "bun run wrangler deploy",
    "dev": "bun run nuxt dev",
    "format": "bun run run-s format:prettier format:trunk",
    "format:prettier": "bun run prettier --write .",
    "format:trunk": "bun run trunk fmt -a",
    "generate": "bun run nuxt generate",
    "lint": "bun run run-s lint:eslint lint:trunk lint:types",
    "lint:eslint": "bun run eslint .",
    "lint:eslint:fix": "bun run eslint . --fix",
    "lint:fix": "bun run run-s lint:eslint:fix lint:trunk:fix",
    "lint:trunk": "bun run trunk check -a",
    "lint:trunk:fix": "bun run trunk check -a --fix",
    "lint:types": "bun run tsc --noEmit",
    "postinstall": "bun run-s postinstall:trunk:install postinstall:trunk:upgrade postinstall:prepare types format",
    "postinstall:prepare": "bun run nuxt prepare",
    "postinstall:trunk:install": "bun run trunk install",
    "postinstall:trunk:upgrade": "bun run trunk upgrade",
    "preview": "bun run-s build preview:wrangler",
    "preview:wrangler": "bun run wrangler dev",
    "types": "bun run wrangler types",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:unit": "vitest --project unit",
    "test:nuxt": "vitest --project nuxt",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "esbuild",
    "sharp",
    "unrs-resolver",
    "workerd"
  ],
  "type": "module"
}
